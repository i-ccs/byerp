pId\">\n        <el-select v-model=\"queryParams.shopId\" placeholder=\"请选择店铺\" clearable @change=\"handleQuery\">\n         <el-option\n            v-for=\"item in shopList\"\n            :key=\"item.id\"\n            :label=\"item.name\"\n            :value=\"item.id\">\n          </el-option>\n        </el-select>\n      </el-form-item>\n      <el-form-item label=\"类型\" prop=\"pullType\">\n        <el-select v-model=\"queryParams.pullType\" placeholder=\"请选择类型\" clearable @change=\"handleQuery\">\n          <el-option label=\"拉取订单\" value=\"ORDER\"></el-option>\n          <el-option label=\"拉取退款\" value=\"REFUND\"></el-option>\n          <el-option label=\"拉取商品\" value=\"GOODS\"></el-option>\n\n        </el-select>\n      </el-form-item>\n      <el-form-item>\n        <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"handleQuery\">搜索</el-button>\n        <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-row :gutter=\"10\" class=\"mb8\">\n      <right-toolbar :showSearch.sync=\"showSearch\" @queryTable=\"getList\"></right-toolbar>\n    </el-row>\n\n    <el-table v-loading=\"loading\" :data=\"lists\" >\n<!--      <el-table-column type=\"selection\" width=\"55\" align=\"center\" />-->\n      <el-table-column label=\"ID\" align=\"center\" prop=\"id\" />\n      <el-table-column label=\"店铺\" align=\"center\" prop=\"shopId\" />\n      <el-table-column label=\"平台\" align=\"center\" prop=\"shopType\" >\n        <template slot-scope=\"scope\">\n          <el-tag size=\"small\" v-if=\"scope.row.shopType === 1\">天猫</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.shopType === 2\">京东</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"类型\" align=\"center\" prop=\"pullType\" >\n        <template slot-scope=\"scope\">\n          <el-tag size=\"small\" v-if=\"scope.row.pullType === 'GOODS'\">拉取商品</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.pullType === 'ORDER'\">拉取订单</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.pullType === 'REFUND'\">拉取退款</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"方式\" align=\"center\" prop=\"pullWay\" />\n\n      <el-table-column label=\"参数\" align=\"center\" prop=\"pullParams\" />\n      <el-table-column label=\"结果\" align=\"center\" prop=\"pullResult\" />\n      <el-table-column label=\"耗时（ms）\" align=\"center\" prop=\"duration\" />\n      <el-table-column label=\"时间\" align=\"center\" prop=\"pullTime\" />\n\n    </el-table>\n\n    <pagination\n      v-show=\"total>0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n\n\n  </div>\n</template>\n\n<script>\nimport {listShop} from \"@/api/shop/shop\";\n\nexport default {\n  name: \"Order\",\n  data() {\n    return {\n      // 显示搜索条件\n      showSearch: true,\n      // 总条数\n      total: 0,\n      // 遮罩层\n      loading: true,\n      lists:[],\n      shopList:[],\n      skuList:[],\n      // 是否显示弹出层\n      detailOpen:false,\n      skuListLoading:false,\n      // 查询参数\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        pullType: 'ORDER'\n      },\n      // 表单参数\n      form: {\n        erpGoodsSkuId:null,\n        id:null\n      },\n      rules: {\n        id: [\n          { required: true, message: \"不能为空\", trigger: \"blur\" }\n        ],\n        erpGoodsSkuId: [\n          { required: true, message: \"不能为空\", trigger: \"blur\" }\n        ],\n      }\n    };\n  },\n  created() {\n    listShop({type: 500}).then(response => {\n        this.shopList = response.rows;\n      });\n    this.getList();\n  },\n  mounted() {\n    if(this.$route.query.shopId){\n        this.queryParams.shopId = this.$route.query.shopId\n    }\n  },\n  methods: {\n    /** 查询淘宝订单列表 */\n    getList() {\n      this.loading = true;\n      listShopPullLogs(this.queryParams).then(response => {\n        this.lists = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n    },\n    /** 搜索按钮操作 */\n    handleQuery() {\n      this.queryParams.pageNum = 1;\n      this.getList();\n    },\n    /** 重置按钮操作 */\n    resetQuery() {\n      this.resetForm(\"queryForm\");\n      this.handleQuery();\n    }\n  }\n};\n</script>\n"],"mappings":";;;;;;AAsEA,IAAAA,KAAA,GAAAC,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCAEA;EACAC,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACA;MACAC,UAAA;MACA;MACAC,KAAA;MACA;MACAC,OAAA;MACAC,KAAA;MACAC,QAAA;MACAC,OAAA;MACA;MACAC,UAAA;MACAC,cAAA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;QACAC,QAAA;MACA;MACA;MACAC,IAAA;QACAC,aAAA;QACAC,EAAA;MACA;MACAC,KAAA;QACAD,EAAA,GACA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAL,aAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IAAA,IAAAC,KAAA;IACA,IAAAC,cAAA;MAAAC,IAAA;IAAA,GAAAC,IAAA,WAAAC,QAAA;MACAJ,KAAA,CAAAhB,QAAA,GAAAoB,QAAA,CAAAC,IAAA;IACA;IACA,KAAAC,OAAA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,SAAAC,MAAA,CAAAC,KAAA,CAAAC,MAAA;MACA,KAAAtB,WAAA,CAAAsB,MAAA,QAAAF,MAAA,CAAAC,KAAA,CAAAC,MAAA;IACA;EACA;EACAC,OAAA;IACA,eACAL,OAAA,WAAAA,QAAA;MAAA,IAAAM,MAAA;MACA,KAAA9B,OAAA;MACA+B,gBAAA,MAAAzB,WAAA,EAAAe,IAAA,WAAAC,QAAA;QACAQ,MAAA,CAAA7B,KAAA,GAAAqB,QAAA,CAAAC,IAAA;QACAO,MAAA,CAAA/B,KAAA,GAAAuB,QAAA,CAAAvB,KAAA;QACA+B,MAAA,CAAA9B,OAAA;MACA;IACA;IACA,aACAgC,WAAA,WAAAA,YAAA;MACA,KAAA1B,WAAA,CAAAC,OAAA;MACA,KAAAiB,OAAA;IACA;IACA,aACAS,UAAA,WAAAA,WAAA;MACA,KAAAC,SAAA;MACA,KAAAF,WAAA;IACA;EACA;AACA","ignoreList":[]}]}