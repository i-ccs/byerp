end({shopId: this.queryParams.shopId, ids: this.ids}).then(response => {\n        this.$modal.msgSuccess(\"发货成功！\");\n        this.getList()\n      })\n    },\n\n    getUUID(len, radix) {\n      var chars = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'.split('');\n      var uuid = [], i;\n      radix = radix || chars.length;\n      if (len) {\n        for (i = 0; i < len; i++) uuid[i] = chars[0 | Math.random() * radix];\n      } else {\n        var r;\n        uuid[8] = uuid[13] = uuid[18] = uuid[23] = '-';\n        uuid[14] = '4';\n        for (i = 0; i < 36; i++) {\n          if (!uuid[i]) {\n            r = 0 | Math.random() * 16;\n            uuid[i] = chars[(i == 19) ? (r & 0x3) | 0x8 : r];\n          }\n        }\n      }\n      return uuid.join('');\n    }\n  }\n};\n</script>\n"],"mappings":";;;;;;;;;;;;;;;AAqSAA,OAAA;AAEA,IAAAC,KAAA,GAAAD,OAAA;AACA,IAAAE,MAAA,GAAAF,OAAA;AACA,IAAAG,SAAA,GAAAH,OAAA;AAKA,IAAAI,UAAA,GAAAJ,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCAGA;EACAK,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACA;MACAC,OAAA;MACAC,WAAA;MACA;MACAC,GAAA;MACAC,QAAA;MACAC,eAAA;MACA;MACAC,MAAA;MACA;MACAC,QAAA;MACA;MACAC,UAAA;MACA;MACAC,KAAA;MACA;MACAC,KAAA;MACA;MACAC,WAAA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;QACAC,YAAA;QACAC,UAAA;QACAC,WAAA;QACAC,MAAA;MACA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,OAAA;MACA;MACA;MACAC,IAAA;QACAD,OAAA;QACAE,SAAA;MACA;MACAC,SAAA;MACAC,WAAA;MACAC,WAAA;MACA;MACAC,KAAA;QACAJ,SAAA;UAAAK,QAAA;UAAAC,OAAA;QAAA;QACAR,OAAA;UAAAO,QAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IAAA,IAAAC,KAAA;IACA,KAAAC,MAAA;IACA,IAAAC,cAAA;MAAAC,IAAA,OAAAtB,WAAA,CAAAI;IAAA,GAAAmB,IAAA,WAAAC,QAAA;MACAL,KAAA,CAAA3B,QAAA,GAAAgC,QAAA,CAAAC,IAAA;MACA,IAAAN,KAAA,CAAA3B,QAAA,IAAA2B,KAAA,CAAA3B,QAAA,C