ect/' + roleId,\n    method: 'get'\n  })\n}\n\n// 新增菜单\nexport function addMenu(data) {\n  return request({\n    url: '/scm-api/system/menu',\n    method: 'post',\n    data: data\n  })\n}\n\n// 修改菜单\nexport function updateMenu(data) {\n  return request({\n    url: '/scm-api/system/menu',\n    method: 'put',\n    data: data\n  })\n}\n\n// 删除菜单\nexport function delMenu(menuId) {\n  return request({\n    url: '/scm-api/system/menu/' + menuId,\n    method: 'delete'\n  })\n}\n"],"mappings":";;;;;;;;;;;;;AAAA,IAAAA,QAAA,GAAAC,sBAAA,CAAAC,OAAA;AAEA;AACO,SAASC,QAAQA,CAACC,KAAK,EAAE;EAC9B,OAAO,IAAAC,gBAAO,EAAC;IACbC,GAAG,EAAE,2BAA2B;IAChCC,MAAM,EAAE,KAAK;IACbC,MAAM,EAAEJ;EACV,CAAC,CAAC;AACJ;;AAEA;AACO,SAASK,OAAOA,CAACC,MAAM,EAAE;EAC9B,OAAO,IAAAL,gBAAO,EAAC;IACbC,GAAG,EAAE,uBAAuB,GAAGI,MAAM;IACrCH,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;;AAEA;AACO,SAASI,UAAUA,CAAA,EAAG;EAC3B,OAAO,IAAAN,gBAAO,EAAC;IACbC,GAAG,EAAE,iCAAiC;IACtCC,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;;AAEA;AACO,SAASK,kBAAkBA,CAACC,MAAM,EAAE;EACzC,OAAO,IAAAR,gBAAO,EAAC;IACbC,GAAG,EAAE,0CAA0C,GAAGO,MAAM;IACxDN,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;;AAEA;AACO,SAASO,OAAOA,CAACC,IAAI,EAAE;EAC5B,OAAO,IAAAV,gBAAO,EAAC;IACbC,GAAG,EAAE,sBAAsB;IAC3BC,MAAM,EAAE,MAAM;IACdQ,IAAI,EAAEA;EACR,CAAC,CAAC;AACJ;;AAEA;AACO,SAASC,UAAUA,CAACD,IAAI,EAAE;EAC/B,OAAO,IAAAV,gBAAO,EAAC;IACbC,GAAG,EAAE,sBAAsB;IAC3BC,MAAM,EAAE,KAAK;IACbQ,IAAI,EAAEA;EACR,CAAC,CAAC;AACJ;;AAEA;AACO,SAASE,OAAOA,CAACP,MAAM,EAAE;EAC9B,OAAO,IAAAL,gBAAO,EAAC;IACbC,GAAG,EAAE,uBAAuB,GAAGI,MAAM;IACrCH,MAAM,EAAE;EACV,CAAC,CAAC;AACJ","ignoreList":[]}]}