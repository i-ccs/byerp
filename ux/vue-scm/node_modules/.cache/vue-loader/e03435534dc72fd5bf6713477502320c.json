{"remainingRequest":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/src/views/merchant/index.vue?vue&type=script&lang=js","dependencies":[{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/src/views/merchant/index.vue","mtime":1768550697000},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/node_modules/cache-loader/dist/cjs.js","mtime":1776695538156},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/node_modules/babel-loader/lib/index.js","mtime":1776695539264},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/node_modules/cache-loader/dist/cjs.js","mtime":1776695538156},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-scm/node_modules/vue-loader/lib/index.js","mtime":1776695539460}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA0HA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/merchant","sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-form :model=\"queryParams\" ref=\"queryForm\" size=\"small\" :inline=\"true\" v-show=\"showSearch\" label-width=\"68px\">\n      <el-form-item label=\"客户名称\" prop=\"nickName\">\n        <el-input\n          v-model=\"queryParams.nickName\"\n          placeholder=\"请输入客户名称\"\n          clearable\n          @keyup.enter.native=\"handleQuery\"\n        />\n      </el-form-item>\n      <el-form-item label=\"登录账号\" prop=\"userName\">\n        <el-input\n          v-model=\"queryParams.userName\"\n          placeholder=\"请输入客户名称\"\n          clearable\n          @keyup.enter.native=\"handleQuery\"\n        />\n      </el-form-item>\n       <el-form-item label=\"状态\" prop=\"status\">\n        <el-select v-model=\"queryParams.status\" placeholder=\"状态\" clearable>\n         <el-option label=\"正常\" value=\"0\"></el-option>\n         <el-option label=\"停用\" value=\"1\"></el-option>\n        </el-select>\n      </el-form-item>\n\n      <el-form-item>\n        <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"handleQuery\">搜索</el-button>\n        <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-row :gutter=\"10\" class=\"mb8\">\n      <el-col :span=\"1.5\">\n        <el-button\n          type=\"primary\"\n          plain\n          icon=\"el-icon-plus\"\n          size=\"mini\"\n          @click=\"handleAdd\"\n        >新增</el-button>\n      </el-col>\n      <right-toolbar :showSearch.sync=\"showSearch\" @queryTable=\"getList\"></right-toolbar>\n    </el-row>\n\n    <el-table v-loading=\"loading\" :data=\"shopList\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\" align=\"center\" />\n      <el-table-column label=\"ID\" align=\"center\" prop=\"id\" />\n      <el-table-column label=\"登录名\" align=\"center\" prop=\"userName\" />\n       <el-table-column label=\"客户名称\" align=\"center\" prop=\"nickName\" />\n       <el-table-column label=\"手机号\" align=\"center\" prop=\"phonenumber\" />\n       <el-table-column label=\"最后登录时间\" align=\"center\" prop=\"loginDate\" >\n         <template slot-scope=\"scope\">\n           <span>{{ parseTime(scope.row.loginDate) }}</span>\n         </template>\n       </el-table-column>\n      <el-table-column label=\"描述\" align=\"center\" prop=\"remark\" />\n      <el-table-column label=\"状态\" align=\"center\" prop=\"status\" >\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.status === '0'\">正常</el-tag>\n          <el-tag v-if=\"scope.row.status === '1'\">停用</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" align=\"center\" class-name=\"small-padding fixed-width\">\n        <template slot-scope=\"scope\">\n          <el-button\n            size=\"mini\"\n            type=\"text\"\n            icon=\"el-icon-edit\"\n            @click=\"handleUpdate(scope.row)\"\n            v-hasPermi=\"['shop:shop:edit']\"\n          >修改</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <pagination\n      v-show=\"total>0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n\n    <!-- 添加或修改店铺对话框 -->\n    <el-dialog :title=\"title\" :visible.sync=\"open\" width=\"500px\" append-to-body>\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"80px\">\n        <el-form-item label=\"登录账号\" v-if=\"form.id == undefined\" prop=\"userName\">\n          <el-input v-model=\"form.userName\" placeholder=\"请输入登录账号\" />\n        </el-form-item>\n        <el-form-item label=\"客户名称\" prop=\"nickName\">\n          <el-input v-model=\"form.nickName\" placeholder=\"请输入客户名称\" />\n        </el-form-item>\n        <el-form-item label=\"手机号码\" prop=\"phonenumber\">\n          <el-input v-model=\"form.phonenumber\" placeholder=\"请输入手机号码\" maxlength=\"11\" />\n        </el-form-item>\n        <el-form-item label=\"邮箱\" prop=\"email\">\n          <el-input v-model=\"form.email\" placeholder=\"请输入邮箱\" maxlength=\"50\" />\n        </el-form-item>\n        <el-form-item v-if=\"form.id == undefined\" label=\"用户密码\" prop=\"password\">\n          <el-input v-model=\"form.password\" placeholder=\"请输入用户密码\" type=\"password\" maxlength=\"20\" show-password/>\n        </el-form-item>\n        <el-form-item label=\"描述\" prop=\"remark\">\n          <el-input type=\"textarea\" v-model=\"form.remark\" placeholder=\"请输入描述\" />\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-select v-model=\"form.status\" placeholder=\"状态\">\n            <el-option label=\"正常\" value=\"0\"></el-option>\n            <el-option label=\"停用\" value=\"1\"></el-option>\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button type=\"primary\" @click=\"submitForm\">确 定</el-button>\n        <el-button @click=\"cancel\">取 消</el-button>\n      </div>\n    </el-dialog>\n\n  </div>\n</template>\n\n<script>\nimport {\n  listMerchant,\n  getMerchant,\n  addMerchant,\n  updateMerchant\n} from \"@/api/channel/merchant\";\n\nexport default {\n  name: \"Shop\",\n  data() {\n    return {\n      // 遮罩层\n      loading: true,\n      // 选中数组\n      ids: [],\n      // 非单个禁用\n      single: true,\n      // 非多个禁用\n      multiple: true,\n      // 显示搜索条件\n      showSearch: true,\n      // 总条数\n      total: 0,\n      // 店铺表格数据\n      shopList: [],\n      // 弹出层标题\n      title: \"\",\n      // 是否显示弹出层\n      open: false,\n      // 查询参数\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10\n      },\n      // 表单参数\n      form: {\n        type:null\n      },\n      // 表单校验\n      rules: {\n        userName: [{ required: true, message: \"不能为空\", trigger: \"blur\" }],\n        nickName: [{ required: true, message: \"不能为空\", trigger: \"blur\" }],\n        phonenumber: [{ required: true, message: \"不能为空\", trigger: \"blur\" }],\n        password: [{ required: true, message: \"不能为空\", trigger: \"change\" }],\n        status: [{ required: true, message: \"不能为空\", trigger: \"change\" }]\n      }\n    };\n  },\n  created() {\n    this.getList();\n  },\n  methods: {\n    /** 查询店铺列表 */\n    getList() {\n      this.loading = true;\n      listMerchant(this.queryParams).then(response => {\n        this.shopList = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n    },\n    // 取消按钮\n    cancel() {\n      this.open = false;\n      this.apiOpen = false;\n      this.reset();\n    },\n    // 表单重置\n    reset() {\n      this.form = {};\n      this.resetForm(\"form\");\n    },\n    /** 搜索按钮操作 */\n    handleQuery() {\n      this.queryParams.pageNum = 1;\n      this.getList();\n    },\n    /** 重置按钮操作 */\n    resetQuery() {\n      this.resetForm(\"queryForm\");\n      this.handleQuery();\n    },\n    // 多选框选中数据\n    handleSelectionChange(selection) {\n      this.ids = selection.map(item => item.id)\n      this.single = selection.length!==1\n      this.multiple = !selection.length\n    },\n    /** 新增按钮操作 */\n    handleAdd() {\n      this.reset();\n      this.open = true;\n      this.form.status = '0'\n      this.title = \"添加分销渠道\";\n    },\n    /** 修改按钮操作 */\n    handleUpdate(row) {\n      this.reset();\n      const id = row.id || this.ids\n      getMerchant(id).then(response => {\n        this.form = response.data;\n        this.$nextTick(()=>{\n          this.form.status = response.data.status+'';\n        })\n\n        this.open = true;\n        this.title = \"修改店铺\";\n      });\n    },\n    /** 提交按钮 */\n    submitForm() {\n      this.$refs[\"form\"].validate(valid => {\n        if (valid) {\n          if (this.form.userId != null) {\n            updateMerchant(this.form).then(response => {\n              this.$modal.msgSuccess(\"修改成功\");\n              this.open = false;\n              this.apiOpen = false\n              this.getList();\n            });\n          } else {\n            addMerchant(this.form).then(response => {\n              this.$modal.msgSuccess(\"新增成功\");\n              this.open = false;\n              this.getList();\n            });\n          }\n        }\n      });\n    }\n  }\n};\n</script>\n"]}]}