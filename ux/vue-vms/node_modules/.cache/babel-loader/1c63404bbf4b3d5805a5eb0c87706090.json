rm","handleQuery","resetQuery","handleSelectionChange","selection","map","item","orderNum","length","updateWaybillAccount","_this3","shopId","pullWaybillAccount","console","log","code","$modal","msgSuccess","JSON","stringify","MessageBox","confirm","confirmButtonText","cancelButtonText","catch","isRelogin","show","msgError","handleUpdate","row","_this4","branchName","branchCode","wpCode","getWaybillTemplateList","updateSubmit","_this5","$refs","validate","valid","updateAccount"],"sources":["src/views/vms/shipping/setting/share_ewaybill_account/tao.vue"],"sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-row>\n      <el-form :model=\"queryParams\" ref=\"queryForm\" size=\"small\" :inline=\"true\" v-show=\"showSearch\" label-width=\"108px\">\n        <el-form-item label=\"快递公司编码\" prop=\"deliveryId\">\n          <el-input\n            v-model=\"queryParams.deliveryId\"\n            placeholder=\"请输入快递公司编码\"\n            clearable\n            @keyup.enter.native=\"handleQuery\"\n          />\n        </el-form-item>\n        <el-form-item label=\"面单类型\" prop=\"type\">\n          <el-select v-model=\"queryParams.type\" filterable  placeholder=\"面单类型\">\n            <el-option label=\"自有\" value=\"0\"></el-option>\n            <el-option label=\"商户共享\" value=\"1\"></el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"商户\" prop=\"merchantId\">\n          <el-select v-model=\"queryParams.merchantId\" placeholder=\"请选择商户\" clearable @change=\"handleQuery\">\n            <el-option value=\"0\" label=\"总部\"></el-option>\n            <el-option\n              v-for=\"item in merchantList\"\n              :key=\"item.merchantId\"\n              :label=\"item.name\"\n              :value=\"item.merchantId\">\n            </el-option>\n          </el-select>\n        </el-form-item>\n        <el-form-item>\n          <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"handleQuery\">搜索</el-button>\n          <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n        </el-form-item>\n\n      </el-form>\n\n    </el-row>\n\n\n    <el-row :gutter=\"10\" class=\"mb8\">\n\n      <el-col :span=\"1.5\">\n        <el-button\n          type=\"primary\"\n          plain\n          icon=\"el-icon-time\"\n          size=\"mini\"\n          :loading=\"pullLoading\"\n          @click=\"updateWaybillAccount\"\n        >更新电子面单账户信息</el-button>\n      </el-col>\n\n<!--      <el-col :span=\"1.5\">-->\n\n<!--        <el-button-->\n<!--          type=\"success\"-->\n<!--          plain-->\n<!--          icon=\"el-icon-printer\"-->\n<!--          size=\"mini\"-->\n<!--          @click=\"handleAdd\"-->\n<!--        >手动添加</el-button>-->\n<!--      </el-col>-->\n\n      <right-toolbar :showSearch.sync=\"showSearch\" @queryTable=\"getList\"></right-toolbar>\n    </el-row>\n\n    <el-table v-loading=\"loading\" :data=\"deliverList\" @selection-change=\"handleSelectionChange\">\n<!--       <el-table-column type=\"selection\" width=\"55\" align=\"center\" />-->\n<!--      <el-table-column label=\"ID\" align=\"center\" prop=\"id\" />-->\n      <el-table-column label=\"面单类型\" align=\"center\" prop=\"type\" >\n        <template slot-scope=\"scope\">\n          <el-tag size=\"small\" v-if=\"scope.row.type===0\">自有</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.type===1\">商户共享</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"商户\" align=\"left\" prop=\"merchantId\" >\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.merchantId===0\">总部</el-tag>\n         <span v-else>\n            {{ merchantList.find(x=>x.id === scope.row.merchantId) ? merchantList.find(x=>x.id === scope.row.merchantId).name : '' }}\n         </span>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"网点\" align=\"left\" prop=\"siteName\">\n      </el-table-column>\n      <el-table-column label=\"网点编号\" align=\"center\" prop=\"siteCode\" width=\"100px\" />\n\n      <el-table-column label=\"快递公司编码\" align=\"center\" prop=\"deliveryId\" width=\"100px\" />\n<!--      <el-table-column label=\"客户编码\" align=\"center\" prop=\"sellerShopId\" width=\"100px\" />-->\n      <el-table-column label=\"店铺\" align=\"left\" prop=\"netsiteName\" width=\"200px\">\n        <template slot-scope=\"scope\">\n          {{ shopList.find(x=>x.id == scope.row.shopId) ? shopList.find(x=>x.id == scope.row.shopId).name : '' }}\n        </template>\n      </el-table-column>\n<!--      <el-table-column label=\"已取单号\" align=\"center\" prop=\"allocated\" width=\"100px\" />-->\n<!--      <el-table-column label=\"已取消单号\" align=\"center\" prop=\"cancel\" width=\"100px\" />-->\n<!--      <el-table-column label=\"已回收单号\" align=\"center\" prop=\"recycled\" width=\"100px\" />-->\n      <el-table-column label=\"余额\" align=\"center\" prop=\"available\" width=\"100px\" />\n<!--      <el-table-column label=\"省\" align=\"center\" prop=\"senderProvince\"/>-->\n<!--      <el-table-column label=\"市\" align=\"center\" prop=\"senderCity\"/>-->\n<!--      <el-table-column label=\"区\" align=\"center\" prop=\"senderCounty\"/>-->\n<!--      <el-table-column label=\"发货地址\" align=\"center\" prop=\"senderAddress\"/>-->\n      <el-table-column label=\"发货地址\" align=\"left\" prop=\"provinceName\" width=\"200\">\n        <template slot-scope=\"scope\">\n          {{scope.row.senderProvince}} {{scope.row.senderCity}} {{scope.row.senderCounty}} <br/>\n          {{scope.row.senderAddress}}\n        </template>\n      </el-table-column>\n      <el-table-column label=\"发货人\" align=\"left\" prop=\"provinceName\" width=\"200\">\n        <template slot-scope=\"scope\">\n          {{scope.row.name}} <br/>\n          {{scope.row.mobile}}\n        </template>\n      </el-table-column>\n\n\n      <el-table-column label=\"操作\" align=\"center\" class-name=\"small-padding fixed-width\">\n        <template slot-scope=\"scope\">\n          <el-button v-if=\"scope.row.type==0\"\n            size=\"mini\"\n            type=\"text\"\n            icon=\"el-icon-edit\"\n            @click=\"handleUpdate(scope.row)\"\n          >发货人&快递模版设置</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <pagination\n      v-show=\"total>0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n\n    <!-- 手动添加 -->\n    <el-dialog title=\"发货人&快递模版设置\" :visible.sync=\"updateOpen\" width=\"500px\" append-to-body>\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"120px\">\n        <el-form-item label=\"网点名\" prop=\"branchName\">\n          <el-input v-model=\"form.branchName\" placeholder=\"请输入网点名\" />\n        </el-form-item>\n        <el-form-item label=\"网点编码\" prop=\"branchCode\">\n          <el-input v-model=\"form.branchCode\" placeholder=\"请输入网编码\" />\n        </el-form-item>\n        <el-form-item label=\"快递模块\" prop=\"templateUrl\">\n          <el-select v-model=\"form.templateUrl\" placeholder=\"请选择快递模版\" clearable @change=\"handleQuery\">\n            <el-option\n              v-for=\"item in templateList\"\n              :key=\"item.id\"\n              :label=\"item.templateName\"\n              :value=\"item.templateUrl\">\n            </el-option>\n          </el-select>\n          <el-button\n            size=\"mini\"\n            type=\"text\"\n            @click=\"handlePullTemplate(form.wpCode)\"\n          >更新快递模版</el-button>\n        </el-form-item>\n        <el-form-item label=\"发货人\" prop=\"name\" >\n          <el-input v-model=\"form.name\" placeholder=\"请输入发货人\" />\n        </el-form-item>\n        <el-form-item label=\"发货手机号\" prop=\"mobile\" >\n          <el-input v-model=\"form.mobile\" placeholder=\"请输入发货手机号\" />\n        </el-form-item>\n\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button type=\"primary\" @click=\"updateSubmit\">确 定</el-button>\n        <el-button @click=\"cancel\">取 消</el-button>\n      </div>\n    </el-dialog>\n\n  </div>\n</template>\n\n<script>\nimport '@riophae/vue-treeselect/dist/vue-treeselect.css'\nimport {listMerchant,listMerchantShop} from \"@/api/vms/merchant\";\nimport {\n  getWaybillAccountList, getWaybillTemplateList,\n  pullWaybillAccount, pullWaybillTemplat,\n  updateAccount\n} from \"@/api/vms/ewaybillAccount\";\nimport {MessageBox} from \"element-ui\";\nimport {isRelogin} from \"@/utils/request\";\n\nexport default {\n  name: \"WaybillAccountPdd\",\n  data() {\n    return {\n      // 遮罩层\n      loading: true,\n      pullLoading: false,\n      // 选中数组\n      ids: [],\n      templateList: [],\n      shopList: [],\n      supplierList: [],\n      deliverList: [],\n      merchantList: [],\n      // 非单个禁用\n      single: true,\n      // 非多个禁用\n      multiple: true,\n      // 显示搜索条件\n      showSearch: true,\n      // 总条数\n      total: 0,\n      // 弹出层标题\n      title: \"\",\n      open:false,\n\n      updateOpen:false,\n      // 查询参数\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        shopType: 100,\n        type: '1',\n        merchantId:null\n      },\n      // 打印参数\n      printParams: {\n        deliver: null,\n        printer: null\n      },\n      // 表单参数\n      form: {\n        id:null,\n        siteName:null,\n        siteCode:null,\n        sellerShopId:null,\n        name:null,\n        mobile:null,\n        deliveryId: null,\n        templateUrl: null\n      },\n\n      // 表单校验\n      rules: {\n        siteName: [{ required: true, message: '不能为空', trigger: \"blur\" }],\n        siteCode: [{ required: true, message: '不能为空', trigger: \"blur\" }],\n        templateUrl: [{ required: true, message: '不能为空', trigger: \"blur\" }],\n        name: [{ required: true, message: '不能为空', trigger: \"blur\" }],\n        mobile: [{ required: true, message: '不能为空', trigger: \"blur\" }],\n      }\n    };\n  },\n  created() {\n    listMerchant().then(resp=>{\n      this.merchantList = resp.rows\n      listMerchantShop().then(res=>{\n        this.shopList = res.data\n        this.getList();\n      })\n\n    })\n  },\n  methods: {\n    /** 查询商品管理列表 */\n    getList() {\n      this.loading = true;\n      getWaybillAccountList(this.queryParams).then(response => {\n        this.deliverList = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n\n\n    },\n    // 取消按钮\n    cancel() {\n      this.open = false\n\n      this.updateOpen = false\n      this.reset();\n    },\n    // 表单重置\n    reset() {\n      this.form = {\n        id: null,\n        erpSkuId: null\n      };\n      this.resetForm(\"form\");\n    },\n    /** 搜索按钮操作 */\n    handleQuery() {\n      this.queryParams.pageNum = 1;\n      this.getList();\n    },\n    /** 重置按钮操作 */\n    resetQuery() {\n      this.resetForm(\"queryForm\");\n      this.handleQuery();\n    },\n    // 多选框选中数据\n    handleSelectionChange(selection) {\n      this.ids = selection.map(item => item.orderNum)\n      this.single = selection.length !== 1\n      this.multiple = !selection.length\n    },\n\n    // 更新电子面单信息\n    updateWaybillAccount() {\n      if(this.queryParams.shopId){\n        pullWaybillAccount({shopId: this.queryParams.shopId}).then(response => {\n          console.log('拉取订单接口返回=====',response)\n          if(response.code === 200){\n            this.$modal.msgSuccess(JSON.stringify(response));\n            this.pullLoading = false\n            this.getList()\n          }\n          else if(response.code === 1401) {\n            MessageBox.confirm('Token已过期，需要重新授权！请前往店铺列表重新获取授权！', '系统提示', { confirmButtonText: '前往授权', cancelButtonText: '取消', type: 'warning' }).then(() => {\n              // this.$router.push({path:\"/shop/list\",query:{type:3}})\n            }).catch(() => {\n              isRelogin.show = false;\n            });\n          }else {\n            this.$modal.msgError(JSON.stringify(response));\n            this.pullLoading = false\n          }\n        });\n      }else{\n        this.$modal.msgError(\"请选择店铺\")\n      }\n\n    },\n    handleUpdate(row){\n      this.form.id = row.id\n      this.form.branchName = row.branchName\n      this.form.branchCode = row.branchCode\n      // this.form.sellerShopId = row.sellerShopId\n      this.form.name = row.name\n      this.form.mobile = row.mobile\n      this.form.wpCode = row.wpCode\n      getWaybillTemplateList({wpCode:row.wpCode}).then(resp=>{\n        this.templateList = resp.data\n        this.form.templateUrl = row.templateUrl\n        this.updateOpen = true\n      })\n\n    },\n    updateSubmit(){\n      this.$refs[\"form\"].validate(valid => {\n        if (valid) {\n          updateAccount(this.form).then(resp=>{\n            this.$modal.msgSuccess(\"保存成功\")\n            this.updateOpen =false\n            this.getList()\n          })\n        }\n      })\n\n    },\n  }\n};\n</script>\n"],"mappings":";;;;;;;;;;;;AAkLAA,OAAA;AACA,IAAAC,SAAA,GAAAD,OAAA;AACA,IAAAE,gBAAA,GAAAF,OAAA;AAKA,IAAAG,UAAA,GAAAH,OAAA;AACA,IAAAI,QAAA,GAAAJ,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCAEA;EACAK,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACA;MACAC,OAAA;MACAC,WAAA;MACA;MACAC,GAAA;MACAC,YAAA;MACAC,QAAA;MACAC,YAAA;MACAC,WAAA;MACAC,YAAA;MACA;MACAC,MAAA;MACA;MACAC,QAAA;MACA;MACAC,UAAA;MACA;MACAC,KAAA;MACA;MACAC,KAAA;MACAC,IAAA;MAEAC,UAAA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;QACAC,QAAA;QACAC,IAAA;QACAC,UAAA;MACA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,OAAA;MACA;MACA;MACAC,IAAA;QACAC,EAAA;QACAC,QAAA;QACAC,QAAA;QACAC,YAAA;QACA9B,IAAA;QACA+B,MAAA;QACAC,UAAA;QACAC,WAAA;MACA;MAEA;MACAC,KAAA;QACAN,QAAA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAR,QAAA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAJ,WAAA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACArC,IAAA;UAAAmC,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;QACAN,MAAA;UAAAI,QA