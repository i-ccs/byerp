ange","selection","map","item","handleViewSkuList","row","handleUpdate","_this2","getGoods","handleDelete","_this3","$modal","confirm","delGoods","msgSuccess","catch","submitForm","_this4","$refs","validate","valid","updateGoods","handleExport","download","_objectSpread2","default","concat","Date","getTime","handleImport"],"sources":["src/views/vms/goods/index.vue"],"sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-form :model=\"queryParams\" ref=\"queryForm\" size=\"small\" :inline=\"true\" v-show=\"showSearch\" label-width=\"88px\">\n      <el-form-item label=\"商品名称\" prop=\"name\">\n        <el-input\n          v-model=\"queryParams.name\"\n          placeholder=\"请输入商品名称\"\n          clearable\n          @keyup.enter.native=\"handleQuery\"\n        />\n      </el-form-item>\n      <el-form-item label=\"商品编号\" prop=\"number\">\n        <el-input\n          v-model=\"queryParams.number\"\n          placeholder=\"请输入商品编号\"\n          clearable\n          @keyup.enter.native=\"handleQuery\"\n        />\n      </el-form-item>\n      <el-form-item label=\"状态\" prop=\"disable\">\n        <el-select v-model=\"queryParams.status\" filterable  placeholder=\"状态\">\n          <el-option label=\"销售中\" value=\"1\"></el-option>\n          <el-option label=\"已下架\" value=\"2\"></el-option>\n        </el-select>\n      </el-form-item>\n\n      <el-form-item>\n        <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"handleQuery\">搜索</el-button>\n        <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-row :gutter=\"10\" class=\"mb8\">\n      <el-col :span=\"1.5\">\n        <el-button\n          type=\"primary\"\n          plain\n          icon=\"el-icon-plus\"\n          size=\"mini\"\n          @click=\"handleAdd\"\n        >添加商品</el-button>\n      </el-col>\n<!--      <el-col :span=\"1.5\">-->\n<!--        <el-button-->\n<!--          type=\"success\"-->\n<!--          plain-->\n<!--          icon=\"el-icon-edit\"-->\n<!--          size=\"mini\"-->\n<!--          @click=\"handleImport\"-->\n<!--          v-hasPermi=\"['goods:goods:edit']\"-->\n<!--        >推送到线下渠道店铺</el-button>-->\n<!--      </el-col>-->\n      <!--\n      <el-col :span=\"1.5\">\n        <el-button\n          type=\"danger\"\n          plain\n          icon=\"el-icon-delete\"\n          size=\"mini\"\n          :disabled=\"multiple\"\n          @click=\"handleDelete\"\n          v-hasPermi=\"['goods:goods:remove']\"\n        >删除</el-button>\n      </el-col> -->\n<!--      <el-col :span=\"1.5\">-->\n<!--        <el-button-->\n<!--          type=\"warning\"-->\n<!--          plain-->\n<!--          icon=\"el-icon-download\"-->\n<!--          size=\"mini\"-->\n<!--          @click=\"handleExport\"-->\n<!--          v-hasPermi=\"['goods:goods:export']\"-->\n<!--        >导出</el-button>-->\n<!--      </el-col>-->\n      <right-toolbar :showSearch.sync=\"showSearch\" @queryTable=\"getList\"></right-toolbar>\n    </el-row>\n\n    <el-table v-loading=\"loading\" :data=\"goodsList\" @selection-change=\"handleSelectionChange\">\n       <el-table-column type=\"selection\" width=\"55\" align=\"center\" />\n      <el-table-column label=\"ID\" align=\"center\" prop=\"id\" width=\"125\" />\n      <el-table-column label=\"主图\" align=\"center\" prop=\"image\" width=\"60\">\n        <template slot-scope=\"scope\">\n          <image-preview :src=\"scope.row.image\" :width=\"50\" :height=\"50\"/>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"商品名称\" align=\"left\" prop=\"name\" width=\"300\"/>\n\n      <el-table-column label=\"商品编号\" align=\"center\" prop=\"goodsNum\" width=\"130\"/>\n      <!-- <el-table-column label=\"条码\" align=\"center\" prop=\"barCode\" /> -->\n      <el-table-column label=\"采购价\" align=\"center\" prop=\"purPrice\" />\n\n      <el-table-column label=\"建议零售价\" align=\"center\" prop=\"retailPrice\" />\n      <!-- <el-table-column label=\"单位成本\" align=\"center\" prop=\"unitCost\" /> -->\n\n      <el-table-column label=\"状态\" align=\"center\" prop=\"status\" >\n        <template slot-scope=\"scope\">\n          <el-tag size=\"small\" v-if=\"scope.row.status === 1\">销售中</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.status === 2\">已下架</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" align=\"center\" class-name=\"small-padding fixed-width\">\n        <template slot-scope=\"scope\">\n          <el-button\n            size=\"mini\"\n            type=\"text\"\n            icon=\"el-icon-view\"\n            @click=\"handleViewSkuList(scope.row)\"\n          >查看SKU</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <pagination\n      v-show=\"total>0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n\n\n    <el-dialog :title=\"title\" :visible.sync=\"skuOpen\" width=\"1000px\" append-to-body>\n      <el-table v-loading=\"loading\" :data=\"skuList\">\n        <!-- <el-table-column type=\"selection\" width=\"55\" align=\"center\" /> -->\n        <el-table-column label=\"Sku Id\" align=\"center\" prop=\"id\" />\n        <el-table-column label=\"图片\" align=\"center\" prop=\"colorImage\" width=\"60\">\n          <template slot-scope=\"scope\">\n            <image-preview :src=\"scope.row.colorImage\" :width=\"50\" :height=\"50\"/>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"商品名称\" align=\"left\" prop=\"goodsName\" width=\"288\"/>\n        <el-table-column label=\"SKU名称\" align=\"center\" prop=\"specName\" />\n        <el-table-column label=\"SKU编码\" align=\"center\" prop=\"specNum\" />\n\n        <el-table-column label=\"采购价\" align=\"center\" prop=\"purPrice\" />\n        <el-table-column label=\"建议零售价\" align=\"center\" prop=\"retailPrice\" />\n        <el-table-column label=\"状态\" align=\"center\" prop=\"status\" >\n          <template slot-scope=\"scope\">\n            <el-tag size=\"small\" v-if=\"scope.row.status === 1\">销售中</el-tag>\n            <el-tag size=\"small\" v-if=\"scope.row.status === 2\">已下架</el-tag>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-dialog>\n\n  </div>\n</template>\n\n<script>\nimport { listGoods, getGoods, delGoods, updateGoods } from \"@/api/vms/goods/goods\";\nimport Treeselect from '@riophae/vue-treeselect'\nimport '@riophae/vue-treeselect/dist/vue-treeselect.css'\n\nimport {getToken} from \"@/utils/auth\";\n\nexport default {\n  name: \"Goods\",\n  components: { Treeselect },\n  data() {\n    return {\n      importOpen:false,\n      headers: { 'Authorization': 'Bearer ' + getToken() },\n      // 遮罩层\n      loading: true,\n      // 选中数组\n      ids: [],\n      // 非单个禁用\n      single: true,\n      // 非多个禁用\n      multiple: true,\n      // 显示搜索条件\n      showSearch: true,\n      // 总条数\n      total: 0,\n      // 商品管理表格数据\n      goodsList: [],\n      // 弹出层标题\n      title: \"\",\n      // 是否显示弹出层\n      open: false,\n      skuOpen: false,\n      // 查询参数\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        name: null,\n        image: null,\n        number: null,\n        unitName: null,\n        categoryId: null,\n        barCode: null,\n        status: null,\n        disable: null,\n        supplierId: null,\n        brandId: null,\n\n      },\n      // 表单参数\n      form: {},\n      categoryList: [],\n      categoryTree: [],\n      supplierList: [],\n      skuList: [],\n      // 表单校验\n      rules: {\n\n      }\n    };\n  },\n  created() {\n        this.getList();\n  },\n  methods: {\n    normalizer(node) {\n      return {\n        id: node.id,\n        label: node.value\n      };\n    },\n    buildTree(list, parentId) {\n      let tree = [];\n      for (let i = 0; i < list.length; i++) {\n        if (list[i].parentId === parentId) {\n          let node = {\n            id: list[i].id,\n            label: list[i].name,\n            children: this.buildTree(list, list[i].id)\n          };\n          tree.push(node);\n        }\n      }\n      return tree;\n    },\n    /** 查询商品管理列表 */\n    getList() {\n      this.loading = true;\n      listGoods(this.queryParams).then(response => {\n        this.goodsList = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n    },\n    handleAdd(){\n      this.$router.push('/goods/create');\n    },\n    // 取消按钮\n    cancel() {\n      this.open = false;\n      this.skuOpen = false;\n      this.skuList = []\n      this.reset();\n    },\n    // 表单重置\n    reset() {\n      this.form = {};\n      this.resetForm(\"form\");\n    },\n    /** 搜索按钮操作 */\n    handleQuery() {\n      this.queryParams.pageNum = 1;\n      this.getList();\n    },\n    /** 重置按钮操作 */\n    resetQuery() {\n      this.resetForm(\"queryForm\");\n      this.handleQuery();\n    },\n    // 多选框选中数据\n    handleSelectionChange(selection) {\n      this.ids = selection.map(item => item.id)\n      this.single = selection.length!==1\n      this.multiple = !selection.length\n    },\n    /** 查看SKU List*/\n    handleViewSkuList(row){\n      this.skuList = row.skuList\n      this.skuOpen = true;\n\n    },\n    /** 修改按钮操作 */\n    handleUpdate(row) {\n      this.reset();\n      const id = row.id || this.ids\n      getGoods(id).then(response => {\n        this.form = response.data;\n        this.form.disable = response.data.disable+''\n        this.open = true;\n        this.title = \"修改商品基本信息\";\n      });\n    },\n    /** 删除按钮操作 */\n    handleDelete(row) {\n      const ids = row.id || this.ids;\n      this.$modal.confirm('是否确认删除商品编号为\"' + ids + '\"的数据项？').then(function() {\n        return delGoods(ids);\n      }).then(() => {\n        this.getList();\n        this.$modal.msgSuccess(\"删除成功\");\n      }).catch(() => {});\n    },\n    /** 提交按钮 */\n    submitForm() {\n      this.$refs[\"form\"].validate(valid => {\n        if (valid) {\n          if (this.form.id != null) {\n            updateGoods(this.form).then(response => {\n              this.$modal.msgSuccess(\"修改成功\");\n              this.open = false;\n              this.getList();\n            });\n          }\n        }\n      });\n    },\n    /** 导出按钮操作 */\n    handleExport() {\n      this.download('goods/goods/export', {\n        ...this.queryParams\n      }, `goods_${new Date().getTime()}.xlsx`)\n    },\n    handleImport(){\n      this.importOpen = true\n    }\n  }\n};\n</script>\n"],"mappings":";;;;;;;;;;;;;;AAqJA,IAAAA,MAAA,GAAAC,OAAA;AACA,IAAAC,cAAA,GAAAC,sBAAA,CAAAF,OAAA;AACAA,OAAA;AAEA,IAAAG,KAAA,GAAAH,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCAEA;EACAI,IAAA;EACAC,UAAA;IAAAC,UAAA,EAAAA;EAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,UAAA;MACAC,OAAA;QAAA,iCAAAC,cAAA;MAAA;MACA;MACAC,OAAA;MACA;MACAC,GAAA;MACA;MACAC,MAAA;MACA;MACAC,QAAA;MACA;MACAC,UAAA;MACA;MACAC,KAAA;MACA;MACAC,SAAA;MACA;MACAC,KAAA;MACA;MACAC,IAAA;MACAC,OAAA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;QACAnB,IAAA;QACAoB,KAAA;QACAC,MAAA;QACAC,QAAA;QACAC,UAAA;QACAC,OAAA;QACAC,MAAA;QACAC,OAAA;QACAC,UAAA;QACAC,OAAA;MAEA;MACA;MACAC,IAAA;MACAC,YAAA;MACAC,YAAA;MACAC,YAAA;MACAC,OAAA;MACA;MACAC,KAAA,GAEA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,OAAA;EACA;EACAC,OAAA;IACAC,UAAA,WAAAA,WAAAC,IAAA;MACA;QACAC,EAAA,EAAAD,IAAA,CAAAC,EAAA;QACAC,KAAA,EAAAF,IAAA,CAAAG;MACA;IACA;IACAC,SAAA,WAAAA,UAAAC,IAAA,EAAAC,QAAA;MACA,IAAAC,IAAA;MACA,SAAAC,CAAA,MAAAA,CAAA,GAAAH,IAAA,CAAAI,MAAA,EAAAD,CAAA;QACA,IAAAH,IAAA,CAAAG,CAAA,EAAAF,QAAA,KAAAA,QAAA;UACA,IAAAN,IAAA;YACAC,EAAA,EAAAI,IAAA,CAAAG,CAAA,EAAAP,EAAA;YACAC,KAAA,EAAAG,IAAA,CAAAG,CAAA,EAAA/C,IAAA;YACAiD,QAAA,OAAAN,SAAA,CAAAC,IAAA,EAAAA,IAAA,CAAAG,CAAA,EAAAP,EAAA;UACA;UACAM,IAAA,CAAAI,IAAA,CAAAX,IAAA;QACA;MACA;MACA,OAAAO,IAAA;IACA;IACA,eACAV,OAAA,WAAAA,QAAA;MAAA,IAAAe,KAAA;MACA,KAAA5C