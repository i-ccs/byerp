is.ids}).then(response => {\n        this.$modal.msgSuccess(\"发货成功！\");\n        this.getList()\n      })\n    },\n    getUUID(len, radix) {\n      var chars = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'.split('');\n      var uuid = [], i;\n      radix = radix || chars.length;\n      if (len) {\n        for (i = 0; i < len; i++) uuid[i] = chars[0 | Math.random() * radix];\n      } else {\n        var r;\n        uuid[8] = uuid[13] = uuid[18] = uuid[23] = '-';\n        uuid[14] = '4';\n        for (i = 0; i < 36; i++) {\n          if (!uuid[i]) {\n            r = 0 | Math.random() * 16;\n            uuid[i] = chars[(i == 19) ? (r & 0x3) | 0x8 : r];\n          }\n        }\n      }\n      return uuid.join('');\n    }\n  }\n};\n</script>\n"],"mappings":";;;;;;;;;;;;;;;;AAuMAA,OAAA;AACA,IAAAC,MAAA,GAAAD,OAAA;AAEA,IAAAE,IAAA,GAAAF,OAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;iCASA;EACAG,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACA;MACAC,OAAA;MACA;MACAC,GAAA;MACAC,QAAA;MACA;MACAC,MAAA;MACA;MACAC,QAAA;MACA;MACAC,UAAA;MACA;MACAC,KAAA;MACA;MACAC,KAAA;MACA;MACAC,WAAA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;QACAC,UAAA;QACAC,UAAA;MACA;MACA;MACAC,WAAA;QACAC,OAAA;QACAC,OAAA;MACA;MACA;MACAC,IAAA;MACAC,SAAA;MACAC,WAAA;MACAC,WAAA;MACA;MACAC,KAAA;QACAC,SAAA;UAAAC,QAAA;UAAAC,OAAA;QAAA;MACA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,MAAA;IACA,KAAAC,OAAA;EACA;EACAC,OAAA;IACAC,YAAA,WAAAA,aAAAC,IAAA;MACA;QACA;QACA,IAAAC,UAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAH,IAAA;;QAEA;QACA,OAAAC,UAAA,CAAAG,GAAA,WAAAC,IAAA;UAAA,OAAAA,IAAA,CAAAC,KAAA;QAAA,GAAAC,IAAA;MACA,SAAAC,KAAA;QACA,OAAAR,IAAA;MACA;IACA;IACA,eACAH,OAAA,WAAAA,QAAA;MAAA,IAAAY,KAAA;MACA,KAAAvC,OAAA;MACA,IAAAwC,uBAAA,OAAA/B,WAAA,EAAAgC,IAAA,WAAAC,QAAA;QACAH,KAAA,CAAArB,SAAA,GAAAwB,QAAA,CAAAC,IAAA;QACAJ,KAAA,CAAAjC,KAAA,GAAAoC,QAAA,CAAApC,KAAA;QACAiC,KAAA,CAAAvC,OAAA;MACA;IACA;IAC