{"remainingRequest":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/babel-loader/lib/index.js!/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/src/views/vms/shipping/ewaybillPrint/dou/index.vue?vue&type=script&lang=js","dependencies":[{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/src/views/vms/shipping/ewaybillPrint/dou/index.vue","mtime":1768550697000},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/babel.config.js","mtime":1768550697000},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js","mtime":1776695537488},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/babel-loader/lib/index.js","mtime":1776695538640},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js","mtime":1776695537488},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/vue-loader/lib/index.js","mtime":1776695538856}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["require","_order","_dou","name","data","loading","ids","shopList","single","multiple","showSearch","total","title","getCodeOpen","queryParams","pageNum","pageSize","platformId","sendStatus","printParams","deliver","printer","form","orderList","printerList","deliverList","rules","accountId","required","message","created","openWs","getList","methods","getSkuValues","spec","parsedSpec","JSON","parse","map","item","value","join","error","_this","budadanListOrder","then","response","rows","cancel","reset","id","erpSkuId","resetForm","handleQuery","resetQuery","handleSelectionChange","selection","length","_this2","ws","WebSocket","onopen","console","log","send","stringify","requestID","getUUID","cmd","obj","$modal","onmessage","e","resp","printers","msgSuccess","onerror","msgError","handleGetEwaybillCode","_this3","getWaybillAccountList","getCodeOpenForm","_this4","$refs","validate","valid","shopId","getWaybillCodeAndSend","handlePrintEwaybill","_this5","getWaybillPrintData","printData","list","forEach","x","push","sign","trackNo","params","templateUrl","pushWaybillPrintSuccess","handleShipSend","_this6","pushShipSend","len","radix","chars","split","uuid","i","Math","random","r"],"sources":["src/views/vms/shipping/ewaybillPrint/dou/index.vue"],"sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-row>\n      <el-form :model=\"queryParams\" ref=\"queryForm\" size=\"small\" :inline=\"true\" v-show=\"showSearch\" label-width=\"68px\">\n        <el-form-item label=\"订单号\" prop=\"orderId\">\n          <el-input\n            v-model=\"queryParams.orderId\"\n            placeholder=\"请输入订单号\"\n            clearable\n            @keyup.enter.native=\"handleQuery\"\n          />\n        </el-form-item>\n\n        <el-form-item>\n          <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"handleQuery\">搜索</el-button>\n          <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n        </el-form-item>\n        <el-form-item>\n          <el-select v-model=\"printParams.printer\" placeholder=\"请选择打印机\" clearable>\n            <el-option\n              v-for=\"item in printerList\"\n              :key=\"item.name\"\n              :label=\"item.name\"\n              :value=\"item.name\">\n            </el-option>\n          </el-select>\n\n        </el-form-item>\n      </el-form>\n\n    </el-row>\n\n\n    <el-row :gutter=\"10\" class=\"mb8\">\n<!--      <el-col :span=\"1.5\">-->\n<!--        <el-button-->\n<!--          type=\"primary\"-->\n<!--          plain-->\n<!--          icon=\"el-icon-time\"-->\n<!--          size=\"mini\"-->\n<!--          :disabled=\"multiple\"-->\n<!--          @click=\"handleGetEwaybillCode\"-->\n<!--        >电子面单取号&发货</el-button>-->\n<!--      </el-col>-->\n\n<!--      <el-col :span=\"1.5\">-->\n<!--        <el-button-->\n<!--          type=\"primary\"-->\n<!--          plain-->\n<!--          icon=\"el-icon-time\"-->\n<!--          size=\"mini\"-->\n<!--          :disabled=\"multiple\"-->\n<!--          @click=\"handleGetEwaybillCode\"-->\n<!--        >电子面单取号</el-button>-->\n<!--      </el-col>-->\n\n      <el-col :span=\"1.5\">\n\n        <el-button\n          type=\"success\"\n          plain\n          :disabled=\"multiple\"\n          icon=\"el-icon-printer\"\n          size=\"mini\"\n          @click=\"handlePrintEwaybill\"\n        >电子面单打印</el-button>\n      </el-col>\n<!--      <el-col :span=\"1.5\">-->\n<!--        <el-button-->\n<!--          type=\"danger\"-->\n<!--          plain-->\n<!--          icon=\"el-icon-d-arrow-right\"-->\n<!--          size=\"mini\"-->\n<!--          :disabled=\"multiple\"-->\n<!--          @click=\"handleShipSend\"-->\n<!--        >电子面单发货</el-button>-->\n<!--      </el-col>-->\n      <right-toolbar :showSearch.sync=\"showSearch\" @queryTable=\"getList\"></right-toolbar>\n    </el-row>\n\n    <el-table v-loading=\"loading\" :data=\"orderList\" @selection-change=\"handleSelectionChange\">\n       <el-table-column type=\"selection\" width=\"55\" align=\"center\" />\n<!--      <el-table-column label=\"ID\" align=\"center\" prop=\"id\" />-->\n      <el-table-column label=\"订单号\" align=\"left\" prop=\"orderNum\" width=\"180\">\n        <template slot-scope=\"scope\">\n          <p>{{scope.row.orderNum}}</p>\n\n        </template>\n      </el-table-column>\n      <el-table-column label=\"商品明细\" align=\"center\" width=\"900px\" >\n        <template slot=\"header\">\n          <table>\n            <th>\n              <td width=\"50px\">图片</td>\n              <td width=\"250px\" align=\"left\">商品标题</td>\n              <td width=\"150\" align=\"left\">规格</td>\n              <td width=\"200\" align=\"left\">Sku编码</td>\n              <!--              <td width=\"150\" align=\"left\">平台SkuId</td>-->\n              <td width=\"50\" align=\"left\">数量</td>\n            </th>\n          </table>\n        </template>\n        <template slot-scope=\"scope\" >\n          <el-table :data=\"scope.row.itemList\" :show-header=\"false\" :cell-style=\"{border:0 + 'px' }\"  :row-style=\"{border:0 + 'px' }\" >\n            <el-table-column label=\"商品图片\" width=\"50px\">\n              <template slot-scope=\"scope\">\n                <!--                <el-image  style=\"width: 40px; height: 40px;\" :src=\"scope.row.goodsImg\" :preview-src-list=\"[scope.row.goodsImg]\"></el-image>-->\n                <image-preview :src=\"scope.row.goodsImg\" :width=\"40\" :height=\"40\"/>\n              </template>\n            </el-table-column>\n            <el-table-column label=\"商品名\" align=\"left\" width=\"250px\" prop=\"goodsName\" >\n              <template slot-scope=\"scope\">\n                {{scope.row.goodsName}}\n                <!--                <el-tag size=\"small\" v-if=\"scope.row.refundStatus === 1\">无售后或售后关闭</el-tag>-->\n                <el-tag size=\"small\" v-if=\"scope.row.refundStatus === 2\">售后处理中</el-tag>\n                <el-tag size=\"small\" v-if=\"scope.row.refundStatus === 3\">退款中</el-tag>\n                <el-tag size=\"small\" v-if=\"scope.row.refundStatus === 4\">退款成功</el-tag>\n                <el-tag size=\"small\" v-if=\"scope.row.refundStatus === 11\">已取消</el-tag>\n              </template>\n            </el-table-column>\n            <el-table-column label=\"SKU名\" align=\"left\" prop=\"skuName\" width=\"150\"  :show-overflow-tooltip=\"true\">\n              <template slot-scope=\"scope\">\n                {{ getSkuValues(scope.row.skuName)}}\n              </template>\n            </el-table-column>\n            <el-table-column label=\"Sku编码\" align=\"left\" prop=\"skuCode\" width=\"200\"/>\n            <!--            <el-table-column label=\"平台SkuId\" align=\"left\" prop=\"skuId\" width=\"150\"/>-->\n            <el-table-column label=\"商品数量\" align=\"center\" prop=\"quantity\" width=\"50px\">\n              <template slot-scope=\"scope\">\n                <el-tag size=\"small\" type=\"danger\">{{scope.row.quantity}}</el-tag>\n              </template>\n            </el-table-column>\n          </el-table>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"下单时间\" align=\"center\" prop=\"orderCreateTime\" width=\"180\">\n        <template slot-scope=\"scope\">\n          <span>{{ parseTime(scope.row.orderTime) }}</span>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"备注\" align=\"center\" prop=\"buyerMessage\" >\n        <template slot-scope=\"scope\">\n          <span v-if=\"scope.row.buyerMessage\">买家留言:{{ scope.row.buyerMessage }}</span>\n          <span v-if=\"scope.row.sellerMemo\">卖家备注:{{ scope.row.sellerMemo }}</span>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"收件人\" prop=\"receiverName\" width=\"200px\">\n        <template slot-scope=\"scope\">\n          {{scope.row.receiverName}}&nbsp;\n          {{scope.row.receiverMobile}} <br />\n          {{scope.row.province}} {{scope.row.city}} {{scope.row.town}} <br />\n\n        </template>\n      </el-table-column>\n      <el-table-column label=\"面单号\" align=\"center\" prop=\"waybillCode\" />\n      <el-table-column label=\"取号状态\" align=\"center\" prop=\"waybillStatus\" >\n        <template slot-scope=\"scope\">\n          <el-tag size=\"small\" v-if=\"scope.row.waybillStatus==0\">未取号</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.waybillStatus==1\">已取号</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.waybillStatus==2\">已打印</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.waybillStatus==3\">已发货</el-tag>\n          <el-tag size=\"small\" v-if=\"scope.row.waybillStatus==10\">手动发货</el-tag>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <pagination\n      v-show=\"total>0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n    <!-- 取号 -->\n    <el-dialog title=\"取号\" :visible.sync=\"getCodeOpen\" width=\"500px\" append-to-body>\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"120px\">\n        <el-form-item label=\"电子面单账户\" prop=\"accountId\">\n            <el-select v-model=\"form.accountId\" placeholder=\"请选择电子面单账户\" clearable>\n              <el-option\n                v-for=\"item in deliverList\"\n                :key=\"item.id\"\n                :label=\"item.company\"\n                :value=\"item.id\">\n                <span style=\"float: left\">{{ item.company }}</span>\n                <span style=\"float: right; color: #8492a6; font-size: 13px\" >{{item.netsiteName}}:{{item.amount}}</span>\n              </el-option>\n            </el-select>\n        </el-form-item>\n\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button type=\"primary\" @click=\"getCodeOpenForm\">取号并发货</el-button>\n        <el-button @click=\"cancel\">取 消</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport '@riophae/vue-treeselect/dist/vue-treeselect.css'\nimport {listOrder, getOrder,budadanListOrder } from \"@/api/vms/order\";\n\nimport {\n  getWaybillAccountList,\n  getWaybillCode,\n  getWaybillPrintData,\n  pushWaybillPrintSuccess,\n  pushShipSend, getWaybillCodeAndSend\n} from \"@/api/vms/ewaybill/dou\";\n\n\nexport default {\n  name: \"printDou\",\n  data() {\n    return {\n      // 遮罩层\n      loading: true,\n      // 选中数组\n      ids: [],\n      shopList: [],\n      // 非单个禁用\n      single: true,\n      // 非多个禁用\n      multiple: true,\n      // 显示搜索条件\n      showSearch: true,\n      // 总条数\n      total: 0,\n      // 弹出层标题\n      title: \"\",\n      // 取号弹出\n      getCodeOpen: false,\n      // 查询参数\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        platformId:400,\n        sendStatus: 2,\n      },\n      // 打印参数\n      printParams: {\n        deliver: null,\n        printer: null\n      },\n      // 表单参数\n      form: {},\n      orderList: [],\n      printerList: [],\n      deliverList: [],\n      // 表单校验\n      rules: {\n        accountId: [{ required: true, message: '请选择电子面单账户' }],\n      }\n    };\n  },\n  created() {\n    this.openWs()\n    this.getList();\n  },\n  methods: {\n    getSkuValues(spec){\n      try {\n        // 解析 JSON，返回一个数组\n        const parsedSpec = JSON.parse(spec) || [];\n\n        // 使用 map 提取所有 value，使用 join() 用逗号连接\n        return parsedSpec.map(item => item.value).join(', ') || '';\n      } catch (error) {\n        return spec; // 如果 JSON 解析出错，返回空字符串\n      }\n    },\n    /** 查询商品管理列表 */\n    getList() {\n      this.loading = true;\n      budadanListOrder(this.queryParams).then(response => {\n        this.orderList = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n    },\n    // 取消按钮\n    cancel() {\n      this.getCodeOpen = false;\n      this.reset();\n    },\n    // 表单重置\n    reset() {\n      this.form = {\n        id: null,\n        erpSkuId: null\n      };\n      this.resetForm(\"form\");\n    },\n    /** 搜索按钮操作 */\n    handleQuery() {\n      this.queryParams.pageNum = 1;\n      this.getList();\n    },\n    /** 重置按钮操作 */\n    resetQuery() {\n      this.resetForm(\"queryForm\");\n      this.handleQuery();\n    },\n    // 多选框选中数据\n    handleSelectionChange(selection) {\n      this.ids = selection.map(item => item.id)\n      this.single = selection.length !== 1\n      this.multiple = !selection.length\n    },\n    openWs() {\n      const ws = new WebSocket('ws://127.0.0.1:13888');\n      ws.onopen = () => {\n        console.log('与打印组件建立连接成功: ');\n        // 或打印机\n        ws.send(JSON.stringify({\n          requestID: this.getUUID(),\n          cmd: 'getPrinters',\n          \"version\": \"1.0\"\n        }))\n      };\n      let obj = this.$modal;\n      ws.onmessage = (e) => {\n        const resp = JSON.parse(e.data || '{}')\n        if (resp.cmd === 'getPrinters') {\n          this.printerList = resp.printers\n          obj.msgSuccess(\"打印组件连接成功！\");\n          console.log('打印机列表: ', resp.printers);\n        }\n      };\n      // 当发生错误时触发\n      ws.onerror = function (error) {\n        obj.msgError(\"打印组件连接失败！请安装并启动字节打印组件！\");\n        console.error('WebSocket error:', error);\n        // alert('WebSocket error occurred. Check the console for more details.');\n      };\n    },\n    // 取号弹窗\n    handleGetEwaybillCode() {\n      const ids = this.ids;\n      if (ids) {\n        getWaybillAccountList({}).then(response => {\n          this.deliverList = response.data;\n          if(response.data&&response.data.length >0) {\n            this.form.accountId = response.data[0].id\n          }\n          this.getCodeOpen = true\n        });\n      } else {\n        this.$modal.msgError(\"请选择订单\")\n      }\n    },\n\n    /** 取号提交按钮 */\n    getCodeOpenForm() {\n      this.$refs[\"form\"].validate(valid => {\n        if (valid) {\n          const ids = this.ids;\n          console.log('=========3333========', ids)\n          if (ids) {\n            console.log('===请求参数=====', {shopId: this.queryParams.shopId, ids: ids, accountId: this.form.accountId})\n            getWaybillCodeAndSend({\n              shopId: this.queryParams.shopId,\n              ids: ids,\n              accountId: this.form.accountId\n            }).then(response => {\n              this.$modal.msgSuccess(\"取号成功\")\n              this.getList()\n              this.getCodeOpen = false\n            });\n          } else {\n            this.$modal.msgError(\"请选择订单\")\n          }\n        }\n      });\n    },\n    handlePrintEwaybill() {\n      // if (!this.ws) {\n      //   this.$modal.msgError('打印组件连接失败！请安装并启动微信视频号小单打印组件！');\n      //   this.openWs()\n      // }\n      // if(!this.printParams.deliver){\n      //   this.$modal.msgError('请选择快递公司！');\n      //   return\n      // }\n      if (!this.printParams.printer) {\n        this.$modal.msgError('请选择打印机！');\n        return\n      }\n      const ids = this.ids;\n      getWaybillPrintData({shopId: this.queryParams.shopId, ids: ids}).then(response => {\n        console.log(\"======打印======\", response.data)\n        if (response.data && response.data.length>0) {\n          const ws = new WebSocket('ws://127.0.0.1:13888');\n          ws.onopen = () => {\n            let printData = []\n\n            response.data.list.forEach(x => printData.push(x.printData))\n            let sign = []\n            response.data.list.forEach(x => sign.push(x.sign))\n            // response.data.forEach(x => printData.push(JSON.parse(x.printData)))\n            // console.log('开始打印: 组合打印数据：', printData);\n            // 打印\n\n            response.data.list.forEach(x =>{\n              // debugger\n            ws.send(JSON.stringify(\n              {\n                \"cmd\": \"print\",\n                \"requestID\": this.getUUID(8, 16),\n                \"version\": \"1.0\",\n                \"task\": {\n                  \"taskID\": this.getUUID(8, 10),\n                  \"printer\": this.printParams.printer,\n                  \"preview\": false,\n                  \"documents\": [{\n                    \"docNo\": x.trackNo,//实际打印业务的单号\n                    \"copy\": 1,//打印两份，默认1份\n                    \"contents\": [{\n                      \"params\": response.data.params,\n                      \"signature\": x.sign,//response.data.list[0].sign,\n                      \"encryptedData\": x.printData,//response.data.list[0].printData,//实体打印机打印后是明文，虚拟打印机打印后是收件人脱敏信息\n                      \"templateURL\": response.data.templateUrl ? response.data.templateUrl : \"https://lf6-cm.ecombdstatic.com/obj/logistics-davinci/template/template_jd76.xml\",\n         