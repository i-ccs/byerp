{"remainingRequest":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/src/views/vms/order/wechatEInvoice.vue?vue&type=script&lang=js","dependencies":[{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/src/views/vms/order/wechatEInvoice.vue","mtime":1768550697000},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js","mtime":1776695537488},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/babel-loader/lib/index.js","mtime":1776695538640},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js","mtime":1776695537488},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/vue-loader/lib/index.js","mtime":1776695538856}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["wechatEInvoice.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAoDA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"wechatEInvoice.vue","sourceRoot":"src/views/vms/order","sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-form :model=\"queryParams\" ref=\"queryForm\" size=\"small\" :inline=\"true\" label-width=\"100px\">\n      <el-form-item label=\"订单号\">\n        <el-input\n          v-model=\"queryParams.orderNum\"\n          placeholder=\"请输入订单号\"\n          clearable\n          @keyup.enter.native=\"getList\"\n        />\n      </el-form-item>\n      <el-form-item>\n        <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"getList\">搜索</el-button>\n        <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-table v-loading=\"loading\" :data=\"orderList\" @selection-change=\"handleSelectionChange\">\n      <el-table-column type=\"selection\" width=\"55\" align=\"center\" />\n      <el-table-column label=\"订单号\" align=\"center\" prop=\"orderNum\" />\n      <el-table-column label=\"商品明细\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <div v-for=\"item in scope.row.itemList\" :key=\"item.id\">\n            {{ item.goodsName }} x {{ item.quantity }}\n          </div>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"收件人\" align=\"center\" prop=\"receiverName\" />\n      <el-table-column label=\"地址\" align=\"center\">\n        <template slot-scope=\"scope\">\n          {{ scope.row.province }} {{ scope.row.city }} {{ scope.row.town }} {{ scope.row.address }}\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" align=\"center\">\n        <template slot-scope=\"scope\">\n          <el-button size=\"mini\" type=\"primary\" @click=\"handlePrint(scope.row)\">打印</el-button>\n          <el-button size=\"mini\" type=\"success\" @click=\"handleShip(scope.row)\">发货</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n\n    <pagination\n      v-show=\"total > 0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n  </div>\n</template>\n\n<script>\nimport { listWechatOrders, printInvoice, shipOrder } from \"@/api/vms/order\";\n\nexport default {\n  name: \"WechatEInvoice\",\n  data() {\n    return {\n      loading: false,\n      orderList: [],\n      total: 0,\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        orderNum: null\n      },\n      selectedOrders: []\n    };\n  },\n  methods: {\n    getList() {\n      this.loading = true;\n      listWechatOrders(this.queryParams).then(response => {\n        this.orderList = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n    },\n    resetQuery() {\n      this.queryParams = {\n        pageNum: 1,\n        pageSize: 10,\n        orderNum: null\n      };\n      this.getList();\n    },\n    handleSelectionChange(selection) {\n      this.selectedOrders = selection;\n    },\n    handlePrint(order) {\n      printInvoice(order.id).then(() => {\n        this.$message.success(\"电子面单打印成功！\");\n      });\n    },\n    handleShip(order) {\n      shipOrder(order.id).then(() => {\n        this.$message.success(\"发货成功！\");\n        this.getList();\n      });\n    }\n  },\n  created() {\n    this.getList();\n  }\n};\n</script>\n"]}]}