{"remainingRequest":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/src/views/vms/shipping/setting/logistics_company.vue?vue&type=script&lang=js","dependencies":[{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/src/views/vms/shipping/setting/logistics_company.vue","mtime":1768550697000},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js","mtime":1776695537488},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/babel-loader/lib/index.js","mtime":1776695538640},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/cache-loader/dist/cjs.js","mtime":1776695537488},{"path":"/home/yuan/project/idea/qihangerp-scm-master/ux/vue-vms/node_modules/vue-loader/lib/index.js","mtime":1776695538856}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["logistics_company.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsHA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"logistics_company.vue","sourceRoot":"src/views/vms/shipping/setting","sourcesContent":["<template>\n  <div class=\"app-container\">\n    <el-form :model=\"queryParams\" ref=\"queryForm\" size=\"small\" :inline=\"true\" v-show=\"showSearch\" label-width=\"68px\">\n      <el-form-item label=\"快递公司\" prop=\"name\">\n        <el-input\n          v-model=\"queryParams.name\"\n          placeholder=\"请输入店铺名\"\n          clearable\n          @keyup.enter.native=\"handleQuery\"\n        />\n      </el-form-item>\n      <el-form-item label=\"状态\" prop=\"status\">\n        <el-select v-model=\"queryParams.status\" placeholder=\"状态\" @change=\"handleQuery\">\n          <el-option label=\"启用\" value=\"1\"></el-option>\n          <el-option label=\"禁用\" value=\"0\"></el-option>\n\n        </el-select>\n      </el-form-item>\n\n      <el-form-item>\n        <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"handleQuery\">搜索</el-button>\n        <el-button icon=\"el-icon-refresh\" size=\"mini\" @click=\"resetQuery\">重置</el-button>\n      </el-form-item>\n    </el-form>\n\n    <el-row :gutter=\"10\" class=\"mb8\">\n      <el-col :span=\"1.5\">\n        <el-button\n          type=\"primary\"\n          plain\n          icon=\"el-icon-plus\"\n          size=\"mini\"\n          @click=\"handleAdd\"\n        >新增</el-button>\n      </el-col>\n\n      <right-toolbar :showSearch.sync=\"showSearch\" @queryTable=\"getList\"></right-toolbar>\n    </el-row>\n\n    <el-table v-loading=\"loading\" :data=\"dataList\" >\n<!--      <el-table-column type=\"selection\" width=\"55\" align=\"center\" />-->\n      <el-table-column label=\"id\" align=\"center\" prop=\"id\" />\n      <el-table-column label=\"快递公司\" align=\"center\" prop=\"name\" />\n       <el-table-column label=\"编码\" align=\"center\" prop=\"code\" />\n       <el-table-column label=\"备注\" align=\"center\" prop=\"remark\" />\n       <el-table-column label=\"状态\" align=\"center\" prop=\"status\" >\n         <template slot-scope=\"scope\">\n           <el-tag size=\"small\" v-if=\"scope.row.status === 0 || !scope.row.status\"> 未启用</el-tag>\n           <el-tag size=\"small\" v-if=\"scope.row.status === 1\"> 启用</el-tag>\n         </template>\n       </el-table-column>\n      <el-table-column label=\"操作\" align=\"center\" class-name=\"small-padding fixed-width\">\n        <template slot-scope=\"scope\">\n          <el-button\n            size=\"mini\"\n            v-if=\"scope.row.status === 0 || !scope.row.status\"\n            type=\"text\"\n            icon=\"el-icon-edit\"\n            @click=\"handleUpdateStatus(scope.row)\"\n          >开启</el-button>\n          <el-button\n            size=\"mini\"\n            v-if=\"scope.row.status === 1\"\n            type=\"text\"\n            icon=\"el-icon-delete\"\n            @click=\"handleUpdateStatus(scope.row)\"\n          >关闭</el-button>\n\n        </template>\n      </el-table-column>\n\n    </el-table>\n\n    <pagination\n      v-show=\"total>0\"\n      :total=\"total\"\n      :page.sync=\"queryParams.pageNum\"\n      :limit.sync=\"queryParams.pageSize\"\n      @pagination=\"getList\"\n    />\n    <!-- 添加或修改店铺对话框 -->\n    <el-dialog :title=\"title\" :visible.sync=\"open\" width=\"500px\" append-to-body>\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"120px\">\n        <el-form-item label=\"快递公司名称\" prop=\"name\">\n          <el-input v-model=\"form.name\" placeholder=\"请输入快递公司名称\" />\n        </el-form-item>\n        <el-form-item label=\"快递公司编码\" prop=\"code\">\n          <el-input v-model=\"form.code\" placeholder=\"请输入快递公司编码\" />\n        </el-form-item>\n<!--        <el-form-item label=\"平台\" prop=\"platformId\">-->\n<!--        <el-select v-model=\"form.platformId\" placeholder=\"请选择平台\" clearable >-->\n<!--          <el-option-->\n<!--            v-for=\"item in typeList\"-->\n<!--            :key=\"item.id\"-->\n<!--            :label=\"item.name\"-->\n<!--            :value=\"item.id\">-->\n<!--          </el-option>-->\n<!--        </el-select>-->\n<!--        </el-form-item>-->\n        <el-form-item label=\"描述\" prop=\"remark\">\n          <el-input type=\"textarea\" v-model=\"form.remark\" placeholder=\"请输入描述\" />\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-select v-model=\"form.status\" placeholder=\"请选择状态\">\n            <el-option label=\"启用\" value=\"1\"></el-option>\n            <el-option label=\"禁用\" value=\"0\"></el-option>\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button type=\"primary\" @click=\"submitForm\">确 定</el-button>\n        <el-button @click=\"cancel\">取 消</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport {\n  listLogisticsStatus,\n  updateStatus,\n  addLogistics,\n  updateLogistics\n} from \"@/api/vms/logistics\";\nimport {MessageBox} from \"element-ui\";\nimport {isRelogin} from \"@/utils/request\";\n\nexport default {\n  name: \"Shop\",\n  data() {\n    return {\n      // 遮罩层\n      loading: true,\n      // 选中数组\n      ids: [],\n      // 非单个禁用\n      single: true,\n      // 非多个禁用\n      multiple: true,\n      // 显示搜索条件\n      showSearch: true,\n      // 总条数\n      total: 0,\n      // 店铺表格数据\n      dataList:[],\n      typeList: [],\n      // 弹出层标题\n      title: \"\",\n      // 是否显示弹出层\n      open: false,\n      apiOpen: false,\n      // 查询参数\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        id:null,\n        shopId:null,\n        status:null,\n      },\n      // 表单参数\n      form: {\n        platformId:null,\n        shopId:0,\n        logisticsId:0,\n        status:'1'\n      },\n      // 表单校验\n      rules: {\n        name: [{ required: true, message: \"不能为空\", trigger: \"blur\" }],\n        number: [{ required: true, message: \"不能为空\", trigger: \"blur\" }],\n\n        status: [{ required: true, message: \"不能为空\", trigger: \"blur\" }],\n      }\n    };\n  },\n  created() {\n\n  },\n  mounted() {\n      this.getList();\n\n  },\n  methods: {\n    /** 查询店铺列表 */\n    getList() {\n      this.loading = true;\n\n      listLogisticsStatus(this.queryParams).then(response => {\n        this.dataList = response.rows;\n        this.total = response.total;\n        this.loading = false;\n      });\n    },\n\n    /** 搜索按钮操作 */\n    handleQuery() {\n      this.queryParams.pageNum = 1;\n      this.getList();\n    },\n    /** 重置按钮操作 */\n    resetQuery() {\n      this.resetForm(\"queryForm\");\n      this.handleQuery();\n    },\n    handleUpdateStatus(row){\n      updateStatus({id:row.id,status:row.status}).then(response => {\n        console.log('更新状态====',response)\n        this.getList()\n      })\n    },\n    // 表单重置\n    reset() {\n      this.form = {\n        id: null,\n        name: null,\n        number: null,\n        remark: null,\n        status: null,\n      };\n      this.resetForm(\"form\");\n    },\n    /** 新增按钮操作 */\n    handleAdd() {\n      this.reset();\n      this.open = true;\n      this.title = \"添加快递公司\";\n    },\n    /** 提交按钮 */\n    submitForm() {\n      this.$refs[\"form\"].validate(valid => {\n        if (valid) {\n          if (this.form.id != null) {\n            updateLogistics(this.form).then(response => {\n              this.$modal.msgSuccess(\"修改成功\");\n              this.open = false;\n              this.getList();\n            });\n          } else {\n            addLogistics(this.form).then(response => {\n              this.$modal.msgSuccess(\"新增成功\");\n              this.open = false;\n              this.getList();\n            });\n          }\n        }\n      });\n    },\n    // 取消按钮\n    cancel() {\n      this.open = false;\n      this.reset();\n    }\n  }\n};\n</script>\n"]}]}